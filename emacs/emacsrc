(defvar native-comp-deferred-compilation-deny-list nil)

;; I keep all my emacs-related stuff under ~/lib/emacs
(defvar emacs-root
  (directory-file-name
   (file-name-directory (file-truename (or load-file-name buffer-file-name "~/.emacs"))))
  "Root of the emacs config: the directory containing this file.")

; add all the elisp directories under ~/emacs to my load path
(defun add-path (p)
	 (add-to-list 'load-path
			(concat emacs-root p)))
(add-path "/lisp") ;; all my personal elisp code
(add-path "/lisp/term") ;; terminal stuff
;; NOTE: local-but-shareable packages (e.g. lisp/slack-attention) are NOT put on
;; the global load-path here.  Each is loaded from its own `use-package' block
;; via `:load-path', so it behaves exactly like a fetched package and extracting
;; it later to its own repo is a one-line `:ensure' recipe swap.
  ;;(add-path "/lisp/themes") ;; color themes
