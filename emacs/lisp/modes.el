;; ---------------------------------------------------------------------
;; Minor modes

;; the line number appears in the mode line
(line-number-mode 1)

;; the column number appears in the mode line
(column-number-mode 1)

;; turn on automatic file compression and uncompression
(auto-compression-mode 1)

;; when the mark is active, the region is highlighted
(transient-mark-mode 1)

;; display characters in the range of 160 to 255 as accented
;;(standard-display-european 1)		; show iso8859 chars

;; show the time
(setq display-time-day-and-date 1)
(display-time)
