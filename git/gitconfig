[pull]
	rebase = true
[push]
	default = simple
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[color]
	diff = auto
	status = auto
	branch = auto
	interactive = auto
	ui = true
	pager = true
[color "status"]
	added = green
	changed = red bold
	untracked = magenta bold
[color "branch"]
	remote = yellow
[rerere]
	enabled = true
	autoupdate = true
[merge]
	renamelimit = 20000
[diff]
	mnemonicprefix = true
# Generic base only.  Personal identity and any company settings are layered on
# top by the personal git entry point — see the README ("overlays").
